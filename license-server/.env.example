# ============================================================
# BodegApp - SERVIDOR DE LICENCIAS - Variables de entorno
# Copia este archivo a "license-server/.env" y rellena valores REALES.
# NUNCA commitees el archivo .env. Estos secretos viven SOLO en el servidor.
# Si falta un secreto obligatorio, el servidor NO arranca (fail-fast).
# ============================================================

# --- Secretos OBLIGATORIOS (sin valores por defecto en el código) ---
# Genera cada uno con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY=
SHARED_API_KEY=

# --- Admin inicial (SOLO para el primer arranque; luego borra ADMIN_PASSWORD) ---
# Si no hay usuarios y faltan estas variables, el servidor no arranca.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Red ---
# Por defecto escucha solo en localhost. Cámbialo con cuidado al desplegar.
HOST=127.0.0.1
PORT=3000

# NOTA: la llave privada RSA se genera aparte con:
#   node license-server/generate-keys.js
# y se guarda en license-server/private.key (gitignored). NUNCA se commitea.
