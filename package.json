{
  "name": "bodegapp",
  "productName": "BodegApp",
  "version": "1.26.10617",
  "isModified": false,
  "author": "Codigo Creativo",
  "description": "Sistema de gestion para emprendimientos y bodegas en Venezuela",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:css:prod && electron-forge start",
    "start:nolic": "npm run build:css:prod && cross-env BODEGAPP_DEV_NO_LICENSE=1 electron-forge start",
    "check:secrets": "node scripts/check-no-secrets.js",
    "prepackage": "npm run check:secrets",
    "package": "electron-forge package",
    "premake": "npm run check:secrets && npm run build:css:prod",
    "make": "electron-forge make",
    "make:32": "electron-forge make --arch=ia32",
    "license": "node generate_offline_license.js",
    "build:32": "npm run build:css:prod && npm run make:32",
    "dev": "nodemon server.js",
    "test": "node --require ./test/setup-env.js --experimental-sqlite --test",
    "test:smoke:backend": "node scripts/smoke-backend.js",
    "test:smoke:electron": "node scripts/smoke-electron.js",
    "test:smoke": "npm run test:smoke:backend && npm run test:smoke:electron",
    "prepare": "simple-git-hooks",
    "clean:dev": "node scripts/clean-dev.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch",
    "build:css:prod": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify"
  },
  "dependencies": {
    "@fastify/cors": "^8.3.0",
    "@fastify/multipart": "^7.7.3",
    "@fastify/static": "^6.10.2",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0-rc.12",
    "csv-parser": "^3.0.0",
    "dotenv": "^17.4.2",
    "fast-csv": "^5.0.1",
    "fastify": "^4.21.0",
    "form-data": "^4.0.5",
    "node-machine-id": "^1.1.12",
    "pdfkit": "^0.15.0",
    "portfinder": "^1.0.38",
    "qrcode": "^1.5.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.3.0",
    "@electron-forge/maker-squirrel": "^7.3.0",
    "@electron-forge/maker-wix": "^7.3.0",
    "@electron-forge/maker-zip": "^7.3.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron": "22.3.27",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.38",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "^3.4.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check:secrets -- --staged-only",
    "pre-push": "npm run check:secrets && npm test"
  }
}
