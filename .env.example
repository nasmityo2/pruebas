# ============================================================
# BodegApp - CLIENTE (Electron) - Variables de entorno
# Copia este archivo a ".env" y rellena valores REALES.
# NUNCA commitees el archivo .env (está en .gitignore).
# Si falta una variable obligatoria, la app falla de forma segura (no arranca).
# ============================================================

# --- Secretos del cliente (OBLIGATORIOS, sin valores por defecto en el código) ---
# Genera cada uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRIAL_SECRET_KEY=
HIST_SECRET=
HASH_SECRET=

# --- Servidor de licencias (default: servidor LOCAL, sin dominios externos) ---
# En producción/VPS se cambia aquí, NO en el código.
LICENSE_SERVER_URL=http://127.0.0.1:3000

# --- Respaldo en la nube (OPCIONAL, desactivado por defecto) ---
# Déjalo vacío para no depender de ningún servidor externo (ver Fase 6).
BACKUP_SERVER_URL=

# --- Fallback opcional de tasas (OPCIONAL, vacío = no consultar servidor externo) ---
RATES_FALLBACK_URL=
